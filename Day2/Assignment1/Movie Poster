<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Movie Poster</title>

    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body{
            padding: 20px;
            font-family: Arial, sans-serif;
        }

        #movies{
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            justify-content: center;
        }

        .movie{
            width: 30%;
            text-align: center;
        }

        .movie img{
            width: 100%;
            height: 450px;
            object-fit: cover;
        }

        .movie h2{
            margin-top: 10px;
        }

        .movie p{
            margin: 10px 0;
        }
        .movie{
            width: 30%;
    text-align: center;
    border: 2px solid #ccc;
    padding: 15px;
    border-radius: 10px;
        }

        .book-button{
            background-color: aqua;
            color: black;
            border: none;
            padding: 10px 20px;
            cursor: pointer;
            font-weight: bold;
        }

        .book-button:hover{
            background-color: deepskyblue;
        }
    </style>
</head>

<body>

    <div id="movies">

        <div class="movie">
            <img src="https://assetscdn1.paytm.com/images/cinema/Doctor-Strange--In-The-Multiverse-Of-Madness-r-705x750-36f0e140-b752-11ec-a762-319bdb0970f2.jpg" alt="Doctor Strange">
            <h2>Doctor Strange 2</h2>
            <p>Rating - 4.5</p>
            <button class="book-button">Book Now</button>
        </div>

        <div class="movie">
            <img src="https://assetscdn1.paytm.com/images/cinema/bb2--705x750-cbc15240-8a94-11ec-8efd-6d205f33f529.jpg" alt="Bhool Bhulaiyaa 2">
            <h2>Bhool Bhulaiyaa 2</h2>
            <p>Rating - 4.5</p>
            <button class="book-button">Book Now</button>
        </div>

        <div class="movie">
            <img src="https://assetscdn1.paytm.com/images/cinema/Jayeshbhai-Jordaar---705x750-660c01c0-cf7c-11ec-98b3-41c37f260d1c.jpg" alt="Jayeshbhai Jordaar">
            <h2>Jayeshbhai Jordaar</h2>
            <p>Rating - 4.5</p>
            <button class="book-button">Book Now</button>
        </div>

        <div class="movie">
            <img src="https://assetscdn1.paytm.com/images/cinema/Jurassic-World--Dominion-705x750-b554ee90-cd51-11ec-8d22-2363945d80ef.jpg" alt="Jurassic World">
            <h2>Jurassic World</h2>
            <p>Rating - 4.5</p>
            <button class="book-button">Book Now</button>
        </div>

        <div class="movie">
            <img src="https://assetscdn1.paytm.com/images/cinema/KGF-705x750-76008750-b6fd-11ec-9639-8322852eadd4.jpg" alt="KGF">
            <h2>KGF</h2>
            <p>Rating - 4.5</p>
            <button class="book-button">Book Now</button>
        </div>

        <div class="movie">
            <img src="https://assetscdn1.paytm.com/images/cinema/RRR-North-705x750-fd78d9c0-693d-11ec-bbcd-5d122dc4018b.jpg" alt="RRR">
            <h2>RRR</h2>
            <p>Rating - 4.5</p>
            <button class="book-button">Book Now</button>
        </div>

    </div>

</body>
</html>
